	partition 'Key Measures' = m
		mode: import
		source =
				let
				    Kilde = Table.FromRows(Json.Document(Binary.Decompress(Binary.FromText("i44FAA==", BinaryEncoding.Base64), Compression.Deflate)), let _t = ((type nullable text) meta [Serialized.Text = true]) in type table [Kolonne1 = _t]),
				    #"Endret type" = Table.TransformColumnTypes(Kilde,{{"Kolonne1", type text}}),
				    #"Fjernede kolonner" = Table.RemoveColumns(#"Endret type",{"Kolonne1"})
				in
				    #"Fjernede kolonner"

	changedProperty = Name

	annotation PBI_ResultType = Table

	annotation PBI_NavigationStepName = Navigasjon

