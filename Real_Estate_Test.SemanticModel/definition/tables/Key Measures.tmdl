	measure 'Direct Return Quarter' = SUM(FACT_SRE_PRODUCT_PERFORMANCE[DIRECT_RETURN_QUARTER])
		formatString: Percent
		displayFolder: Performance
		lineageTag: 24aef545-a934-470e-b7f6-4b8e3a06b553

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isCustom":true}

	measure 'Direct Return Quarter Change In %' = ```
			
			VAR CY = [Direct Return Quarter]
			VAR PY = 
			    CALCULATE(
			        [Direct Return Quarter],
			        OFFSET(
			            -1,
			            ALL('Date'[Year Quarter Name]),
			            ORDERBY( 'Date'[Year Quarter Name], ASC)
			        )
			    )
			VAR _perc =  CY-PY
			VAR _format_CY = FORMAT( CY, "0.00 %;0.00 %" )
			VAR _format_PY = FORMAT( PY, "0.00 %;0.00 %" )
			RETURN
			IF(
			    _perc > 0,
			    _format_CY & " " & UNICHAR(129029) & " (" & _format_PY & ")",
			    IF(
			        _perc < 0,
			        _format_CY & " " & UNICHAR(129031) & " (" & _format_PY & ")",
			        _format_CY & " " & UNICHAR(129030) & " (" & _format_PY & ")"
			    )
			)
			```
		displayFolder: Performance
		lineageTag: ad29d27f-a57e-4fb0-bf76-eeb223ae3533

		changedProperty = IsHidden

	measure 'Direct Return Quarter Change In % Color Format' = ```
			
			VAR CY = [Direct Return Quarter]
			VAR PY = 
			    CALCULATE(
			        [Direct Return Quarter],
			        OFFSET(
			            -1,
			            ALL('Date'[Year Quarter Name]),
			            ORDERBY( 'Date'[Year Quarter Name], ASC)
			        )
			    )
			VAR _perc =  CY-PY
			RETURN
			IF(
			    _perc > 0,
			    "Green",
			    IF(
			        _perc < 0,
			        "Red",
			        "Automatic"
			    )
			)
			```
		displayFolder: Performance
		lineageTag: d3f88114-29cb-4d45-bb41-dd17e58fc1e9

		changedProperty = IsHidden

