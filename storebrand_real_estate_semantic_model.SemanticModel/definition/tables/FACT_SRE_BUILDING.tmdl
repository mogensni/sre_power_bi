	measure QoQ_MarkedsVerdi_ColorFormat = ```
			
			VAR CY = ['Quarterly Market Value']
			VAR PY = 
			    CALCULATE(
			        ['Quarterly Market Value'],
			        OFFSET(
			            -1,
			            ALL(DIM_DATE[FULL_YEAR_QUARTER_NAME]),
			            ORDERBY( DIM_DATE[FULL_YEAR_QUARTER_NAME], ASC)
			        )
			    )
			VAR _perc = DIVIDE( CY-PY, PY )
			VAR _format = FORMAT( _perc, "0.0%;0.0%" )
			RETURN
			IF(
			    _perc > 0,
			    "Green",
			    IF(
			        _perc < 0,
			        "Red",
			        "Automatic"
			    )
			)
			```
		lineageTag: a52947a9-bd27-4c9f-adf7-e0553aec3eab

