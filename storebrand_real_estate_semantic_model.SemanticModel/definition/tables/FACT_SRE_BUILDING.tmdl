table FACT_SRE_BUILDING
	lineageTag: 5a939af5-6882-4c3d-b2a5-1be1ebed47c8

	measure 'Number of Properties' =
			CALCULATE (
			            DISTINCTCOUNT ( DIM_SRE_PROPERTY['Property Name'] ),
			            FILTER ( 'FACT_SRE_BUILDING', ['Valuation (NOK)'] > 0 )
			        )
		formatString: 0
		lineageTag: 72ca50f5-61d1-415d-812f-94acf57a4df2

	measure 'Quarterly Market Value' = ```

			    calculate(
			        sum(FACT_SRE_BUILDING['Valuation (NOK)']),
			        FACT_SRE_BUILDING['Valuation (NOK)'] > 0
			    )
			```
		lineageTag: 6122fb15-aca4-42f2-bcab-4dbff4f03f19

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure YoY_MarkedsVerdi_% = ```
			
			VAR CY = ['Quarterly Market Value']
			VAR PY = 
			    CALCULATE(
			        ['Quarterly Market Value'],
			        OFFSET(
			            -4,
			            ALL(DIM_DATE[FULL_YEAR_QUARTER_NAME]),
			            ORDERBY( DIM_DATE[FULL_YEAR_QUARTER_NAME], ASC)
			        )
			    )
			VAR _perc = DIVIDE( CY-PY, PY )
			VAR _format = FORMAT( _perc, "0.00 %;0.00 %" )
			RETURN
			IF(
			    ISBLANK(PY),
			    "",
			    IF(
			        _perc > 0,
			        _format & " " & UNICHAR(129029),
			        IF(
			            _perc < 0,
			            _format & "  " & UNICHAR(129031),
			            _format & "  " & UNICHAR(129030)
			        )
			    )
			)
			```
		lineageTag: 6f788e80-77d7-4b8e-b4d2-b2dbe8e496a2

	measure PQ =
			CALCULATE(
			        ['Quarterly Market Value'],
