	measure Quarter_DirectReturn_%_ColorFormat = ```
			
			VAR CY = [QUARTER_DIRECT_RETURN]
			VAR PY = 
			    CALCULATE(
			        [QUARTER_DIRECT_RETURN],
			        OFFSET(
			            -1,
			            ALL(DIM_DATE[FULL_YEAR_QUARTER_NAME]),
			            ORDERBY( DIM_DATE[FULL_YEAR_QUARTER_NAME], ASC)
			        )
			    )
			VAR _perc =  CY-PY
			RETURN
			IF(
			    _perc > 0,
			    "Green",
			    IF(
			        _perc < 0,
			        "Red",
			        "Automatic"
			    )
			)
			```
