table FACT_SRE_PRODUCT_PERFORMANCE
	lineageTag: 2e43da7a-4fb0-4405-96b9-46800f452f8e

	measure Quarter_DirectReturn_% = ```
			
			VAR CY = [QUARTER_DIRECT_RETURN]
			VAR PY = 
			    CALCULATE(
			        [QUARTER_DIRECT_RETURN],
			        OFFSET(
			            -1,
			            ALL(DIM_DATE[FULL_YEAR_QUARTER_NAME]),
			            ORDERBY( DIM_DATE[FULL_YEAR_QUARTER_NAME], ASC)
			        )
			    )
			VAR _perc =  CY-PY
			VAR _format_CY = FORMAT( CY, "0.00 %;0.00 %" )
			VAR _format_PY = FORMAT( PY, "0.00 %;0.00 %" )
			RETURN
			IF(
			    _perc > 0,
			    _format_CY & " " & UNICHAR(129029) & " (" & _format_PY & ")",
			    IF(
			        _perc < 0,
			        _format_CY & " " & UNICHAR(129031) & " (" & _format_PY & ")",
			        _format_CY & " " & UNICHAR(129030) & " (" & _format_PY & ")"
			    )
			)
			```
		lineageTag: ad29d27f-a57e-4fb0-bf76-eeb223ae3533

